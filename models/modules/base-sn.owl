  <core:CorrectionInstruction rdf:about="http://example.org/suryanamaskar/base-sn#BalanceWeightEvenlyInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Balance weight evenly on both feet.</core:correctionText>
    <rdfs:label>BalanceWeightEvenlyInstruction</rdfs:label>
  </core:CorrectionInstruction>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#WeightOnHeelsOnlyError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#DistributeWeightEvenlyInstruction"/>
    <rdfs:label>WeightOnHeelsOnlyError</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Weight is shifted to the heels only.</core:errorDescription>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#AlignPalmsAtChestInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label>AlignPalmsAtChestInstruction</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Align the palms at the chest.</core:correctionText>
  </owl:NamedIndividual>
  <core:Pose rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose03">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#WeightOnHeelsOnlyError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RoundedBackError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#ExcessiveKneeBendError"/>
    <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:hasRule>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#ForwardBendFromHipsRule">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
        <rdfs:label>ForwardBendFromHipsRule</rdfs:label>
        <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bend forward from the hips.</core:ruleDescription>
      </owl:NamedIndividual>
    </core:hasRule>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#SpineElongatedRule"/>
    <core:hasRule>
      <core:PostureRule rdf:about="http://example.org/suryanamaskar/base-sn#HeadRelaxedRule">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relax the head and neck downward.</core:ruleDescription>
        <rdfs:label>HeadRelaxedRule</rdfs:label>
      </core:PostureRule>
    </core:hasRule>
    <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose04"/>
    <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose02"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Feet"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Ankle"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Hip"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Neck"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Knee"/>
    <rdfs:label>BaseSN_Pose03</rdfs:label>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</core:poseNumber>
    <core:hasConstraint>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#HipHingeConstraint">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
        <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Forward fold with a hip hinge movement.</core:constraintDescription>
        <rdfs:label>HipHingeConstraint</rdfs:label>
      </owl:NamedIndividual>
    </core:hasConstraint>
    <core:hasConstraint>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#StableLegSupportConstraint">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
        <rdfs:label>StableLegSupportConstraint</rdfs:label>
        <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stable support through both legs.</core:constraintDescription>
      </owl:NamedIndividual>
    </core:hasConstraint>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#Padahastasana"/>
    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hroom/Om Suryaya Namah</core:hasMantra>
    <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Swadhisthana</core:hasChakra>
    <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">StandingBentTwoFeet</core:hasSupportType>
    <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose10"/>
  </core:Pose>
  <core:CorrectionInstruction rdf:about="http://example.org/suryanamaskar/base-sn#CenterBodyInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>CenterBodyInstruction</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Center the body and return to neutral alignment.</core:correctionText>
  </core:CorrectionInstruction>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#LowerChestProperlyInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label>LowerChestProperlyInstruction</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower the chest properly.</core:correctionText>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#MirroredLungeConstraint">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdfs:label>MirroredLungeConstraint</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Same lunge structure on the opposite side.</core:constraintDescription>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#KeepElbowsCloseInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the elbows close.</core:correctionText>
    <rdfs:label>KeepElbowsCloseInstruction</rdfs:label>
  </owl:NamedIndividual>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#PoorBalanceError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Standing balance is unstable.</core:errorDescription>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#CenterBodyInstruction"/>
    <rdfs:label>PoorBalanceError</rdfs:label>
  </core:PoseError>
  <core:CorrectionInstruction rdf:about="http://example.org/suryanamaskar/base-sn#KeepArmsStraightInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the arms straight.</core:correctionText>
    <rdfs:label>KeepArmsStraightInstruction</rdfs:label>
  </core:CorrectionInstruction>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#LowerBackOverarchingError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>LowerBackOverarchingError</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower back is bent too much.</core:errorDescription>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LengthenSpineInstruction"/>
    <core:hasCorrection>
      <core:CorrectionInstruction rdf:about="http://example.org/suryanamaskar/base-sn#GentleBackbendInstruction">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>GentleBackbendInstruction</rdfs:label>
        <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the backbend gentle and controlled.</core:correctionText>
      </core:CorrectionInstruction>
    </core:hasCorrection>
    <core:hasCorrection>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#LiftUpwardFirstInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <rdfs:label>LiftUpwardFirstInstruction</rdfs:label>
        <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lift upward before entering the backbend.</core:correctionText>
      </owl:NamedIndividual>
    </core:hasCorrection>
  </core:PoseError>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#KneeBeyondAnkleError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection>
      <core:CorrectionInstruction rdf:about="http://example.org/suryanamaskar/base-sn#AlignFrontKneeInstruction">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>AlignFrontKneeInstruction</rdfs:label>
        <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Align the front knee above or near the ankle.</core:correctionText>
      </core:CorrectionInstruction>
    </core:hasCorrection>
    <rdfs:label>KneeBeyondAnkleError</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Front knee moves too far beyond the ankle.</core:errorDescription>
  </core:PoseError>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#CollapsedPostureError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <core:hasCorrection>
      <core:CorrectionInstruction rdf:about="http://example.org/suryanamaskar/base-sn#LiftChestInstruction">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lift the chest.</core:correctionText>
        <rdfs:label>LiftChestInstruction</rdfs:label>
      </core:CorrectionInstruction>
    </core:hasCorrection>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#CenterBodyInstruction"/>
    <rdfs:label>CollapsedPostureError</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Overall posture is collapsed.</core:errorDescription>
  </owl:NamedIndividual>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#OverextensionError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#GentleBackbendInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Backbend is forced too much.</core:errorDescription>
    <rdfs:label>OverextensionError</rdfs:label>
  </core:PoseError>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#RaisedShouldersError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#RelaxShouldersInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shoulders are lifted too much.</core:errorDescription>
    <rdfs:label>RaisedShouldersError</rdfs:label>
  </core:PoseError>
  <core:PoseConstraint rdf:about="http://example.org/suryanamaskar/base-sn#OneLegLungeSupportConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>OneLegLungeSupportConstraint</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lunge support with one leg forward and hands grounded.</core:constraintDescription>
  </core:PoseConstraint>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#ForwardBendConstraint">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdfs:label>ForwardBendConstraint</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Controlled standing forward bend.</core:constraintDescription>
  </owl:NamedIndividual>
  <core:PostureRule rdf:about="http://example.org/suryanamaskar/base-sn#ControlledLoweringRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>ControlledLoweringRule</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower the body with control.</core:ruleDescription>
  </core:PostureRule>
  <core:CorrectionInstruction rdf:about="http://example.org/suryanamaskar/base-sn#MaintainHipPositionInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the hips slightly raised.</core:correctionText>
    <rdfs:label>MaintainHipPositionInstruction</rdfs:label>
  </core:CorrectionInstruction>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#BentArmsError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Arms are not fully extended.</core:errorDescription>
    <rdfs:label>BentArmsError</rdfs:label>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#KeepArmsStraightInstruction"/>
  </core:PoseError>
  <core:PostureRule rdf:about="http://example.org/suryanamaskar/base-sn#ChestLiftedRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>ChestLiftedRule</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lift the chest forward and upward.</core:ruleDescription>
  </core:PostureRule>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#LiftChestForwardUpwardInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label>LiftChestForwardUpwardInstruction</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lift the chest forward and upward.</core:correctionText>
  </owl:NamedIndividual>
  <core:PoseConstraint rdf:about="http://example.org/suryanamaskar/base-sn#BackExtensionWithPelvisGroundedConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>BackExtensionWithPelvisGroundedConstraint</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Backward spinal extension with the pelvis grounded.</core:constraintDescription>
  </core:PoseConstraint>
  <core:PostureRule rdf:about="http://example.org/suryanamaskar/base-sn#StableStandingRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>StableStandingRule</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Maintain stable standing alignment.</core:ruleDescription>
  </core:PostureRule>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#SymmetricalEndingConstraint">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetrical standing ending posture.</core:constraintDescription>
    <rdfs:label>SymmetricalEndingConstraint</rdfs:label>
  </owl:NamedIndividual>
  <core:PoseConstraint rdf:about="http://example.org/suryanamaskar/base-sn#EightPointSupportConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>EightPointSupportConstraint</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Support through eight body contact points.</core:constraintDescription>
  </core:PoseConstraint>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#HipsDroppedFullyError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>HipsDroppedFullyError</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hips are dropped fully to the floor.</core:errorDescription>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#MaintainHipPositionInstruction"/>
  </core:PoseError>
  <core:PoseConstraint rdf:about="http://example.org/suryanamaskar/base-sn#MildSpinalExtensionConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild spinal extension with stable lower body.</core:constraintDescription>
    <rdfs:label>MildSpinalExtensionConstraint</rdfs:label>
  </core:PoseConstraint>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#LiftChestForwardInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label>LiftChestForwardInstruction</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lift the chest forward.</core:correctionText>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#CalmAlignmentRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Return to calm and centered alignment.</core:ruleDescription>
    <rdfs:label>CalmAlignmentRule</rdfs:label>
  </owl:NamedIndividual>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#ElbowsWideError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#KeepElbowsCloseInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elbows are too wide.</core:errorDescription>
    <rdfs:label>ElbowsWideError</rdfs:label>
  </core:PoseError>
  <core:PostureRule rdf:about="http://example.org/suryanamaskar/base-sn#EightPointContactRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Maintain eight point contact.</core:ruleDescription>
    <rdfs:label>EightPointContactRule</rdfs:label>
  </core:PostureRule>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#WeakBackLegError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Back leg is not extended or engaged properly.</core:errorDescription>
    <rdfs:label>WeakBackLegError</rdfs:label>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#ExtendBackLegInstruction"/>
  </core:PoseError>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#ChestNotLoweredError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LowerChestProperlyInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chest is not lowered correctly.</core:errorDescription>
    <rdfs:label>ChestNotLoweredError</rdfs:label>
  </core:PoseError>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#TuckElbowsInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the elbows close to the body.</core:correctionText>
    <rdfs:label>TuckElbowsInstruction</rdfs:label>
  </owl:NamedIndividual>
  <core:PostureRule rdf:about="http://example.org/suryanamaskar/base-sn#FrontKneeAlignedRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the front knee aligned above or near the ankle.</core:ruleDescription>
    <rdfs:label>FrontKneeAlignedRule</rdfs:label>
  </core:PostureRule>
  <core:PostureRule rdf:about="http://example.org/suryanamaskar/base-sn#BackLegExtendedRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the back leg extended.</core:ruleDescription>
    <rdfs:label>BackLegExtendedRule</rdfs:label>
  </core:PostureRule>
  <core:PostureRule rdf:about="http://example.org/suryanamaskar/base-sn#SpinalExtensionRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Extend the spine with control.</core:ruleDescription>
    <rdfs:label>SpinalExtensionRule</rdfs:label>
  </core:PostureRule>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#NeckStrainError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LengthenSpineInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neck is strained.</core:errorDescription>
    <rdfs:label>NeckStrainError</rdfs:label>
  </core:PoseError>
</rdf:RDF>
