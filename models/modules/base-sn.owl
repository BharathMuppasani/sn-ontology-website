<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:core="http://example.org/suryanamaskar/core#"
   xmlns:dc="http://purl.org/dc/elements/1.1/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#RoundedBackError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Back is rounded.</core:errorDescription>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LengthenSpineInstruction"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#BendFromHipsInstruction"/>
    <rdfs:label xml:lang="en">RoundedBackError</rdfs:label>
    <rdfs:label xml:lang="hi">गोल पीठ की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose05">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vishuddhi</core:hasChakra>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ElbowsControlledRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#CoreEngagedRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#BodyStraightLineRule"/>
    <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose04"/>
    <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#ChaturangaDandasana"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RaisedHipsError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#ElbowsFlaredError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#SaggingHipsError"/>
    <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HandsAndFeet</core:hasSupportType>
    <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Shoulder"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Core"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Legs"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Wrist"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Elbow"/>
    <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#ArmAndToeSupportConstraint"/>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</core:poseNumber>
    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hraum/Om Khagaya Namah</core:hasMantra>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <rdfs:label xml:lang="en">BaseSN_Pose05</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा ०५</rdfs:label>
    <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose06"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#HeadRelaxedRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relax the head and neck downward.</core:ruleDescription>
    <rdfs:label xml:lang="en">HeadRelaxedRule</rdfs:label>
    <rdfs:label xml:lang="hi">सिर और गर्दन ढीले रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#SymmetricalStandingConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdfs:label xml:lang="en">SymmetricalStandingConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">दोनों पैरों पर संतुलित खड़े रहने की बाध्यता</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetrical standing with balanced weight on both feet.</core:constraintDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#PalmsMisalignedError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#AlignPalmsAtChestInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Palms are not aligned properly.</core:errorDescription>
    <rdfs:label xml:lang="en">PalmsMisalignedError</rdfs:label>
    <rdfs:label xml:lang="hi">हथेलियों के गलत संरेखण की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#SaggingHipsError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#KeepBodyAlignedInstruction"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#EngageCoreInstruction"/>
    <rdfs:label xml:lang="en">SaggingHipsError</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर के मध्य भाग के नीचे धंसने की त्रुटि</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hips are sagging downward.</core:errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#HipsDroppedFullyError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">HipsDroppedFullyError</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर के मध्य भाग को पूरी तरह नीचे गिराने की त्रुटि</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hips are dropped fully to the floor.</core:errorDescription>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#MaintainHipPositionInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose03">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#WeightOnHeelsOnlyError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RoundedBackError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#ExcessiveKneeBendError"/>
    <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ForwardBendFromHipsRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#SpineElongatedRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#HeadRelaxedRule"/>
    <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose04"/>
    <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose02"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Feet"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Ankle"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Hip"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Neck"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Knee"/>
    <rdfs:label xml:lang="en">BaseSN_Pose03</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा ०३</rdfs:label>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</core:poseNumber>
    <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#HipHingeConstraint"/>
    <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#StableLegSupportConstraint"/>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#Padahastasana"/>
    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hroom/Om Suryaya Namah</core:hasMantra>
    <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Swadhisthana</core:hasChakra>
    <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">StandingBentTwoFeet</core:hasSupportType>
    <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose10"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose02">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose11"/>
    <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#HastaUtthanasana"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Hip"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Neck"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Arms"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chest"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Shoulder"/>
    <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose03"/>
    <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">StandingTwoFeet</core:hasSupportType>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ControlledBackbendRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ArmsRaisedOverheadRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ChestOpenRule"/>
    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hreem/Om Ravaye Namah</core:hasMantra>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RaisedShouldersError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#BentArmsError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#LowerBackOverarchingError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#NeckStrainError"/>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</core:poseNumber>
    <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#MildSpinalExtensionConstraint"/>
    <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vishuddhi</core:hasChakra>
    <rdfs:label xml:lang="en">BaseSN_Pose02</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा ०२</rdfs:label>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose01"/>
    <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose08">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose07"/>
    <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HandsAndFeet</core:hasSupportType>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Arms"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Ankle"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Shoulder"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Knee"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Hip"/>
    <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#Parvatasana"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#UnstableLegsError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RoundedBackError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#WristOverloadError"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#WeightDistributedRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#HipsRaisedRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#SpineElongatedRule"/>
    <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hreem/Om Marichaye Namah</core:hasMantra>
    <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose09"/>
    <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#HandsAndFeetSupportConstraint"/>
    <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vishuddhi</core:hasChakra>
    <rdfs:label xml:lang="en">BaseSN_Pose08</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा ०८</rdfs:label>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</core:poseNumber>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ChestLiftedRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">ChestLiftedRule</rdfs:label>
    <rdfs:label xml:lang="hi">छाती उठी हुई रखें</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lift the chest forward and upward.</core:ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Variant"/>
    <rdfs:comment>Base 12 pose Surya Namaskar sequence used at IIT BHU, based on the Sivananda Yoga Vedanta Centre tradition.</rdfs:comment>
    <rdfs:label xml:lang="en">BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU</rdfs:label>
    <rdfs:label xml:lang="hi">सूर्य नमस्कार (शिवानंद योग वेदांत केंद्र)</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#FrontKneeAlignedRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the front knee aligned above or near the ankle.</core:ruleDescription>
    <rdfs:label xml:lang="en">FrontKneeAlignedRule</rdfs:label>
    <rdfs:label xml:lang="hi">सामने का घुटना सही स्थिति में रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#MaintainHipPositionInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the hips slightly raised.</core:correctionText>
    <rdfs:label xml:lang="en">MaintainHipPositionInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर की स्थिति स्थिर रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose07">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</core:poseNumber>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#ShoulderTensionError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#CompressedLowerBackError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#OverextensionError"/>
    <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose08"/>
    <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#BackExtensionWithPelvisGroundedConstraint"/>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Neck"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Arms"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chest"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Shoulder"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ShouldersRelaxedRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#SpinalExtensionRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ChestLiftedRule"/>
    <rdfs:label xml:lang="en">BaseSN_Pose07</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा ०७</rdfs:label>
    <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#Bhujangasana"/>
    <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Swadhisthana</core:hasChakra>
    <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose06"/>
    <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prone</core:hasSupportType>
    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hraam/Om Hiranyagarbhaya Namah</core:hasMantra>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#SoftenKneesInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">SoftenKneesInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">घुटनों को हल्का ढीला रखें</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Soften the knees as needed.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#TuckElbowsInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the elbows close to the body.</core:correctionText>
    <rdfs:label xml:lang="en">TuckElbowsInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">कोहनियों को अंदर रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose10">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose11"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#ExcessiveKneeBendError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RoundedBackError"/>
