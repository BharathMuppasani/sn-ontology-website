    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hraum/Om Arkaya Namah</core:hasMantra>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#CompressedLowerBackError"/>
