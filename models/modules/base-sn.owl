  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#LowerChestProperlyInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">LowerChestProperlyInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">छाती को सही ढंग से नीचे लाएँ</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower the chest properly.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#SymmetricalEndingConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetrical standing ending posture.</core:constraintDescription>
    <rdfs:label xml:lang="en">SymmetricalEndingConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">अंत में संतुलित स्थिति में खड़े रहने की बाध्यता</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#CenterBodyInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">CenterBodyInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को संतुलित करें</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Center the body and return to neutral alignment.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#KeepBodyAlignedInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">KeepBodyAlignedInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को सीध में रखें</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the body aligned in one straight line.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#AlignFrontKneeInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">AlignFrontKneeInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">सामने के घुटने को सही स्थिति में रखें</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Align the front knee above or near the ankle.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#StabilizeLegsInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stabilize and align the legs.</core:correctionText>
    <rdfs:label xml:lang="en">StabilizeLegsInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">पैरों को स्थिर रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BodyStraightLineRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the body in one straight line.</core:ruleDescription>
    <rdfs:label xml:lang="en">BodyStraightLineRule</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को सीधी रेखा में रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#StableStandingRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">StableStandingRule</rdfs:label>
    <rdfs:label xml:lang="hi">स्थिर खड़े रहें</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Maintain stable standing alignment.</core:ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#RaisedShouldersError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#RelaxShouldersInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shoulders are lifted too much.</core:errorDescription>
    <rdfs:label xml:lang="en">RaisedShouldersError</rdfs:label>
    <rdfs:label xml:lang="hi">कंधों के अधिक उठने की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ElbowsWideError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#KeepElbowsCloseInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elbows are too wide.</core:errorDescription>
    <rdfs:label xml:lang="en">ElbowsWideError</rdfs:label>
    <rdfs:label xml:lang="hi">बहुत फैली हुई कोहनियों की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ShoulderTensionError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#RelaxShouldersInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shoulders are tense.</core:errorDescription>
    <rdfs:label xml:lang="en">ShoulderTensionError</rdfs:label>
    <rdfs:label xml:lang="hi">कंधों में तनाव की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose01">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Neck"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Palms"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chest"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Shoulder"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Feet"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#PalmsTogetherRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#UprightPostureRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ShouldersRelaxedRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ChestOpenRule"/>
    <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">StandingTwoFeet</core:hasSupportType>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#PalmsMisalignedError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#CollapsedChestError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RoundedShouldersError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#UnevenWeightError"/>
    <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose02"/>
    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hraam/Om Mitraya Namah</core:hasMantra>
    <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose12"/>
    <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <rdfs:label xml:lang="en">BaseSN_Pose01</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा ०१</rdfs:label>
    <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#Pranamasana"/>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#SymmetricalStandingConstraint"/>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</core:poseNumber>
    <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anahata</core:hasChakra>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#CollapsedPostureError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LiftChestInstruction"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#CenterBodyInstruction"/>
    <rdfs:label xml:lang="en">CollapsedPostureError</rdfs:label>
    <rdfs:label xml:lang="hi">धंसी हुई शरीर मुद्रा की त्रुटि</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Overall posture is collapsed.</core:errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BackLegExtendedRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the back leg extended.</core:ruleDescription>
    <rdfs:label xml:lang="en">BackLegExtendedRule</rdfs:label>
    <rdfs:label xml:lang="hi">पीछे का पैर सीधा रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#SpineElongatedRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the spine elongated.</core:ruleDescription>
    <rdfs:label xml:lang="en">SpineElongatedRule</rdfs:label>
    <rdfs:label xml:lang="hi">रीढ़ लंबी रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BalanceWeightEvenlyInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Balance weight evenly on both feet.</core:correctionText>
    <rdfs:label xml:lang="en">BalanceWeightEvenlyInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर का भार दोनों पैरों पर समान रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#CoreEngagedRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">CoreEngagedRule</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को भीतर से सक्रिय रखें</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the core engaged.</core:ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#HandsAndFeetSupportConstraint">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">HandsAndFeetSupportConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">हाथों और पैरों से शरीर को सहारा देने की बाध्यता</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hands and feet support in an inverted V shape.</core:constraintDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#NeckStrainError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LengthenSpineInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neck is strained.</core:errorDescription>
    <rdfs:label xml:lang="en">NeckStrainError</rdfs:label>
    <rdfs:label xml:lang="hi">गर्दन में खिंचाव की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#CalmAlignmentRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Return to calm and centered alignment.</core:ruleDescription>
    <rdfs:label xml:lang="en">CalmAlignmentRule</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को शांत और संतुलित रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#KeepElbowsCloseInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the elbows close.</core:correctionText>
    <rdfs:label xml:lang="en">KeepElbowsCloseInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">कोहनियों को शरीर के पास रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:imports rdf:resource="http://example.org/suryanamaskar/core"/>
    <rdfs:label xml:lang="en">Surya Namaskar Base Sequence Ontology</rdfs:label>
    <rdfs:label xml:lang="hi">सूर्य नमस्कार का आधारभूत अनुक्रम ऑन्टोलॉजी</rdfs:label>
    <dc:title>Surya Namaskar Base Sequence Ontology</dc:title>
    <dc:description>Base SN variant ontology containing Base SN variant individual, pose occurrences, sequence relations, and Base SN-specific correction resources.</dc:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#UnevenWeightError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Weight is not balanced on both feet.</core:errorDescription>
    <rdfs:label xml:lang="en">UnevenWeightError</rdfs:label>
    <rdfs:label xml:lang="hi">असमान भार की त्रुटि</rdfs:label>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#BalanceWeightEvenlyInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#LiftChestForwardInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">LiftChestForwardInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">छाती को आगे उठाएँ</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lift the chest forward.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ExtendBackLegInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">ExtendBackLegInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">पीछे के पैर को पूरी तरह सीधा रखें</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Extend the back leg fully.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#AlignPalmsAtChestInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">AlignPalmsAtChestInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">हथेलियों को छाती के सामने सही रखें</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Align the palms at the chest.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#RelaxShouldersInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relax the shoulders.</core:correctionText>
    <rdfs:label xml:lang="en">RelaxShouldersInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">कंधों को ढीला रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#LiftChestForwardUpwardInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">LiftChestForwardUpwardInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">छाती को आगे और ऊपर उठाएँ</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lift the chest forward and upward.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ArmAndToeSupportConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdfs:label xml:lang="en">ArmAndToeSupportConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">हाथों और पैरों के सहारे शरीर को संभालने की बाध्यता</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Full body support on arms and toes.</core:constraintDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#LowerBackOverarchingError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">LowerBackOverarchingError</rdfs:label>
    <rdfs:label xml:lang="hi">निचली पीठ के अत्यधिक झुकाव की त्रुटि</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower back is bent too much.</core:errorDescription>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LengthenSpineInstruction"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#GentleBackbendInstruction"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LiftUpwardFirstInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#RoundedShouldersError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shoulders are rounded forward.</core:errorDescription>
    <rdfs:label xml:lang="en">RoundedShouldersError</rdfs:label>
    <rdfs:label xml:lang="hi">गोल कंधों की त्रुटि</rdfs:label>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#RelaxShouldersInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#WeakBackLegError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Back leg is not extended or engaged properly.</core:errorDescription>
    <rdfs:label xml:lang="en">WeakBackLegError</rdfs:label>
    <rdfs:label xml:lang="hi">पीछे के पैर की कमजोरी की त्रुटि</rdfs:label>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#ExtendBackLegInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ControlledLoweringRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">ControlledLoweringRule</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को धीरे और नियंत्रित तरीके से नीचे लाएँ</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower the body with control.</core:ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#OverextensionError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#GentleBackbendInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Backbend is forced too much.</core:errorDescription>
    <rdfs:label xml:lang="en">OverextensionError</rdfs:label>
    <rdfs:label xml:lang="hi">अत्यधिक खिंचाव की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose06">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manipura</core:hasChakra>
    <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EightPointSupport</core:hasSupportType>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</core:poseNumber>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#ChestNotLoweredError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#ElbowsWideError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#HipsDroppedFullyError"/>
    <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Hands"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Elbow"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Knee"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chest"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chin"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Feet"/>
    <rdfs:label xml:lang="en">BaseSN_Pose06</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा ०६</rdfs:label>
    <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#AshtangaNamaskara"/>
    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hrah/Om Pushne Namah</core:hasMantra>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#EightPointContactRule"/>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ControlledLoweringRule"/>
    <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose05"/>
    <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose07"/>
    <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#EightPointSupportConstraint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#PoorBalanceError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Standing balance is unstable.</core:errorDescription>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#CenterBodyInstruction"/>
    <rdfs:label xml:lang="en">PoorBalanceError</rdfs:label>
    <rdfs:label xml:lang="hi">अस्थिर संतुलन की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#WeightDistributedRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Distribute weight evenly between hands and feet.</core:ruleDescription>
    <rdfs:label xml:lang="en">WeightDistributedRule</rdfs:label>
    <rdfs:label xml:lang="hi">भार समान रूप से रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#KneeBeyondAnkleError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#AlignFrontKneeInstruction"/>
    <rdfs:label xml:lang="en">KneeBeyondAnkleError</rdfs:label>
    <rdfs:label xml:lang="hi">घुटने के टखने से आगे जाने की त्रुटि</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Front knee moves too far beyond the ankle.</core:errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#GentleBackbendInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">GentleBackbendInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">हल्का पीछे झुकें</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the backbend gentle and controlled.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#HipsRaisedRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Raise the hips upward.</core:ruleDescription>
    <rdfs:label xml:lang="en">HipsRaisedRule</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को ऊपर उठाकर रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#RaisedHipsError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#KeepBodyAlignedInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hips are raised too high.</core:errorDescription>
    <rdfs:label xml:lang="en">RaisedHipsError</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर के मध्य भाग के अधिक उठने की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ChestOpenRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdfs:label xml:lang="en">ChestOpenRule</rdfs:label>
    <rdfs:label xml:lang="hi">छाती खुली रखें</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the chest open.</core:ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#LiftUpwardFirstInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">LiftUpwardFirstInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">पहले शरीर को ऊपर उठाएँ, फिर पीछे झुकें</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lift upward before entering the backbend.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ChestNotLoweredError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LowerChestProperlyInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chest is not lowered correctly.</core:errorDescription>
    <rdfs:label xml:lang="en">ChestNotLoweredError</rdfs:label>
    <rdfs:label xml:lang="hi">छाती को ठीक से नीचे न लाने की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#MildSpinalExtensionConstraint">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mild spinal extension with stable lower body.</core:constraintDescription>
    <rdfs:label xml:lang="en">MildSpinalExtensionConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">रीढ़ को हल्का पीछे झुकाने की बाध्यता</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ElbowsFlaredError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#TuckElbowsInstruction"/>
    <rdfs:label xml:lang="en">ElbowsFlaredError</rdfs:label>
    <rdfs:label xml:lang="hi">बाहर फैली हुई कोहनियों की त्रुटि</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elbows are moving outward.</core:errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#StableLegSupportConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdfs:label xml:lang="en">StableLegSupportConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">पैरों से स्थिर सहारा बनाए रखने की बाध्यता</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stable support through both legs.</core:constraintDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#LiftChestInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lift the chest.</core:correctionText>
    <rdfs:label xml:lang="en">LiftChestInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">छाती उठाएँ</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#KeepArmsStraightInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the arms straight.</core:correctionText>
    <rdfs:label xml:lang="en">KeepArmsStraightInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">बाहों को सीधा रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ForwardBendConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdfs:label xml:lang="en">ForwardBendConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">नियंत्रित रूप से आगे झुकने की बाध्यता</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Controlled standing forward bend.</core:constraintDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ElbowsControlledRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdfs:label xml:lang="en">ElbowsControlledRule</rdfs:label>
    <rdfs:label xml:lang="hi">कोहनियों को नियंत्रित रखें</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the elbows close and controlled.</core:ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#CompressedLowerBackError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LengthenSpineInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower back is compressed.</core:errorDescription>
    <rdfs:label xml:lang="en">CompressedLowerBackError</rdfs:label>
    <rdfs:label xml:lang="hi">दबी हुई निचली पीठ की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#WristOverloadError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">WristOverloadError</rdfs:label>
    <rdfs:label xml:lang="hi">कलाइयों पर अत्यधिक भार की त्रुटि</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Too much weight is placed on the wrists.</core:errorDescription>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#PushHipsUpwardInstruction"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#DistributeWeightEvenlyInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BendFromHipsInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">BendFromHipsInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">कमर से आगे की ओर झुकें</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bend forward from the hips.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#PushHipsUpwardInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Push the hips upward.</core:correctionText>
    <rdfs:label xml:lang="en">PushHipsUpwardInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को ऊपर उठाएँ</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#UprightPostureRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdfs:label xml:lang="en">UprightPostureRule</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर सीधा रखें</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Maintain an upright posture.</core:ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#UnstableLegsError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#StabilizeLegsInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legs are unstable or poorly aligned.</core:errorDescription>
    <rdfs:label xml:lang="en">UnstableLegsError</rdfs:label>
    <rdfs:label xml:lang="hi">अस्थिर पैरों की त्रुटि</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#LengthenSpineInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">LengthenSpineInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">रीढ़ को लंबा रखें</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lengthen the spine.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#EightPointContactRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Maintain eight point contact.</core:ruleDescription>
    <rdfs:label xml:lang="en">EightPointContactRule</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर के आठ बिंदुओं का संपर्क बनाए रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ShouldersRelaxedRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdfs:label xml:lang="en">ShouldersRelaxedRule</rdfs:label>
    <rdfs:label xml:lang="hi">कंधे ढीले रखें</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the shoulders relaxed.</core:ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#OneLegLungeSupportConstraint">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">OneLegLungeSupportConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">एक पैर आगे रखकर संतुलन बनाए रखने की बाध्यता</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lunge support with one leg forward and hands grounded.</core:constraintDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#WeightOnHeelsOnlyError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#DistributeWeightEvenlyInstruction"/>
    <rdfs:label xml:lang="en">WeightOnHeelsOnlyError</rdfs:label>
    <rdfs:label xml:lang="hi">केवल एड़ियों पर भार आने की त्रुटि</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Weight is shifted to the heels only.</core:errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#PalmsTogetherRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the palms together at the chest.</core:ruleDescription>
    <rdfs:label xml:lang="en">PalmsTogetherRule</rdfs:label>
    <rdfs:label xml:lang="hi">हथेलियाँ साथ रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ForwardBendFromHipsRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdfs:label xml:lang="en">ForwardBendFromHipsRule</rdfs:label>
    <rdfs:label xml:lang="hi">कमर से आगे झुकें</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bend forward from the hips.</core:ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#MirroredLungeConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdfs:label xml:lang="en">MirroredLungeConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">दूसरी तरफ भी वही संतुलन दोहराने की बाध्यता</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Same lunge structure on the opposite side.</core:constraintDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#EngageCoreInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">EngageCoreInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को भीतर से सक्रिय करें</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Engage the core.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#HipHingeConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Forward fold with a hip hinge movement.</core:constraintDescription>
    <rdfs:label xml:lang="en">HipHingeConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">कमर से झुकने की बाध्यता</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ControlledBackbendRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the backbend controlled.</core:ruleDescription>
    <rdfs:label xml:lang="en">ControlledBackbendRule</rdfs:label>
    <rdfs:label xml:lang="hi">पीछे झुकना नियंत्रित रखें</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BentArmsError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Arms are not fully extended.</core:errorDescription>
    <rdfs:label xml:lang="en">BentArmsError</rdfs:label>
    <rdfs:label xml:lang="hi">मुड़ी हुई बाहों की त्रुटि</rdfs:label>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#KeepArmsStraightInstruction"/>
  </rdf:Description>
</rdf:RDF>
