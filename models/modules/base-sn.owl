    <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">StandingTwoFeet</core:hasSupportType>
    <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#UprightBackbendConstraint"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BackExtensionWithPelvisGroundedConstraint">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">BackExtensionWithPelvisGroundedConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">निचले भाग को स्थिर रखते हुए ऊपर उठने की बाध्यता</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Backward spinal extension with the pelvis grounded.</core:constraintDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ArmsRaisedOverheadRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">ArmsRaisedOverheadRule</rdfs:label>
    <rdfs:label xml:lang="hi">बाहों को सिर के ऊपर उठाकर रखें</rdfs:label>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Raise the arms overhead.</core:ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#ExcessiveKneeBendError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">ExcessiveKneeBendError</rdfs:label>
    <rdfs:label xml:lang="hi">घुटनों के अत्यधिक मुड़ने की त्रुटि</rdfs:label>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#SoftenKneesInstruction"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Knees are bent too much.</core:errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#UprightBackbendConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Upright posture with a gentle backbend.</core:constraintDescription>
    <rdfs:label xml:lang="en">UprightBackbendConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">सीधा रहते हुए हल्का पीछे झुकने की बाध्यता</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#SpinalExtensionRule">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Extend the spine with control.</core:ruleDescription>
    <rdfs:label xml:lang="en">SpinalExtensionRule</rdfs:label>
    <rdfs:label xml:lang="hi">रीढ़ को नियंत्रित रूप से फैलाएँ</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#DistributeWeightEvenlyInstruction">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">DistributeWeightEvenlyInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">भार को समान रूप से फैलाएँ</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Distribute weight evenly.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose12">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
