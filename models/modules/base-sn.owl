    <rdfs:label xml:lang="en">BaseSN_Pose10</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा १०</rdfs:label>
    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hraim/Om Savitre Namah</core:hasMantra>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#CollapsedChestError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chest is collapsed.</core:errorDescription>
    <rdfs:label xml:lang="en">CollapsedChestError</rdfs:label>
    <rdfs:label xml:lang="hi">धंसी हुई छाती की त्रुटि</rdfs:label>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LiftChestInstruction"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LiftChestForwardInstruction"/>
    <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LiftChestForwardUpwardInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#EightPointSupportConstraint">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">EightPointSupportConstraint</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर के आठ बिंदुओं का सहारा लेने की बाध्यता</rdfs:label>
    <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Support through eight body contact points.</core:constraintDescription>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose04">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
