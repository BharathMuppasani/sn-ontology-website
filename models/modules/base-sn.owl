    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hrah/Om Bhaskaraya Namah</core:hasMantra>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#PoorBalanceError"/>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#CollapsedPostureError"/>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12</core:poseNumber>
    <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose11"/>
    <rdfs:label xml:lang="en">BaseSN_Pose12</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा १२</rdfs:label>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose01"/>
