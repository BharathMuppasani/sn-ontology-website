<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:core="http://example.org/suryanamaskar/core#"
  xmlns:dc="http://purl.org/dc/elements/1.1/"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
>
  <owl:Ontology rdf:about="http://example.org/suryanamaskar/base-sn">
    <owl:imports rdf:resource="http://example.org/suryanamaskar/core"/>
    <rdfs:label>Surya Namaskar Base Sequence Ontology</rdfs:label>
    <dc:title>Surya Namaskar Base Sequence Ontology</dc:title>
    <dc:description>Base SN variant ontology containing Base SN variant individual, pose occurrences, sequence relations, and Base SN-specific correction resources.</dc:description>
  </owl:Ontology>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#ShoulderTensionError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <core:hasCorrection>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#RelaxShouldersInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relax the shoulders.</core:correctionText>
        <rdfs:label>RelaxShouldersInstruction</rdfs:label>
      </owl:NamedIndividual>
    </core:hasCorrection>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shoulders are tense.</core:errorDescription>
    <rdfs:label>ShoulderTensionError</rdfs:label>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose01">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Neck"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Palms"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chest"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Shoulder"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Feet"/>
    <core:hasRule>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#PalmsTogetherRule">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
        <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the palms together at the chest.</core:ruleDescription>
        <rdfs:label>PalmsTogetherRule</rdfs:label>
      </owl:NamedIndividual>
    </core:hasRule>
    <core:hasRule>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#UprightPostureRule">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
        <rdfs:label>UprightPostureRule</rdfs:label>
        <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Maintain an upright posture.</core:ruleDescription>
      </owl:NamedIndividual>
    </core:hasRule>
    <core:hasRule>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#ShouldersRelaxedRule">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
        <rdfs:label>ShouldersRelaxedRule</rdfs:label>
        <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the shoulders relaxed.</core:ruleDescription>
      </owl:NamedIndividual>
    </core:hasRule>
    <core:hasRule>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#ChestOpenRule">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
        <rdfs:label>ChestOpenRule</rdfs:label>
        <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the chest open.</core:ruleDescription>
      </owl:NamedIndividual>
    </core:hasRule>
    <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">StandingTwoFeet</core:hasSupportType>
    <core:hasPossibleError>
      <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#PalmsMisalignedError">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#AlignPalmsAtChestInstruction"/>
        <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Palms are not aligned properly.</core:errorDescription>
        <rdfs:label>PalmsMisalignedError</rdfs:label>
      </core:PoseError>
    </core:hasPossibleError>
    <core:hasPossibleError>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#CollapsedChestError">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
        <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chest is collapsed.</core:errorDescription>
        <rdfs:label>CollapsedChestError</rdfs:label>
        <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LiftChestInstruction"/>
        <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LiftChestForwardInstruction"/>
        <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LiftChestForwardUpwardInstruction"/>
      </owl:NamedIndividual>
    </core:hasPossibleError>
    <core:hasPossibleError>
      <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#RoundedShouldersError">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shoulders are rounded forward.</core:errorDescription>
        <rdfs:label>RoundedShouldersError</rdfs:label>
        <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#RelaxShouldersInstruction"/>
      </core:PoseError>
    </core:hasPossibleError>
    <core:hasPossibleError>
      <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#UnevenWeightError">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Weight is not balanced on both feet.</core:errorDescription>
        <rdfs:label>UnevenWeightError</rdfs:label>
        <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#BalanceWeightEvenlyInstruction"/>
      </core:PoseError>
    </core:hasPossibleError>
    <core:hasNextPose>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose02">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose11"/>
        <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#HastaUtthanasana"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Hip"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Neck"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Arms"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chest"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Shoulder"/>
        <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose03"/>
        <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">StandingTwoFeet</core:hasSupportType>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ControlledBackbendRule"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ArmsRaisedOverheadRule"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ChestOpenRule"/>
        <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hreem/Om Ravaye Namah</core:hasMantra>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RaisedShouldersError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#BentArmsError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#LowerBackOverarchingError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#NeckStrainError"/>
        <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</core:poseNumber>
        <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#MildSpinalExtensionConstraint"/>
        <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vishuddhi</core:hasChakra>
        <rdfs:label>BaseSN_Pose02</rdfs:label>
        <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
        <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose01"/>
        <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
      </owl:NamedIndividual>
    </core:hasNextPose>
    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hraam/Om Mitraya Namah</core:hasMantra>
    <core:repeatsPose>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose12">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#CalmAlignmentRule"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ChestOpenRule"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#StableStandingRule"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Feet"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chest"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Shoulder"/>
        <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#Pranamasana"/>
        <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">StandingTwoFeet</core:hasSupportType>
        <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hrah/Om Bhaskaraya Namah</core:hasMantra>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#PoorBalanceError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#CollapsedPostureError"/>
        <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12</core:poseNumber>
        <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose11"/>
        <rdfs:label>BaseSN_Pose12</rdfs:label>
        <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
        <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose01"/>
        <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anahata</core:hasChakra>
        <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
        <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#SymmetricalEndingConstraint"/>
      </owl:NamedIndividual>
    </core:repeatsPose>
    <core:belongsToVariant>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Variant"/>
        <rdfs:comment>Base 12 pose Surya Namaskar sequence used at IIT BHU, based on the Sivananda Yoga Vedanta Centre tradition.</rdfs:comment>
        <rdfs:label>BaseSN_SivanandaYogaVedantaCentre</rdfs:label>
      </owl:NamedIndividual>
    </core:belongsToVariant>
    <rdfs:label>BaseSN_Pose01</rdfs:label>
    <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#Pranamasana"/>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <core:hasConstraint>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#SymmetricalStandingConstraint">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
        <rdfs:label>SymmetricalStandingConstraint</rdfs:label>
        <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetrical standing with balanced weight on both feet.</core:constraintDescription>
      </owl:NamedIndividual>
    </core:hasConstraint>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</core:poseNumber>
    <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anahata</core:hasChakra>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose11">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chest"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Neck"/>
    <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Arms"/>
    <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
    <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vishuddhi</core:hasChakra>
    <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hraum/Om Arkaya Namah</core:hasMantra>
    <core:hasPossibleError>
      <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#CompressedLowerBackError">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <core:hasCorrection rdf:resource="http://example.org/suryanamaskar/base-sn#LengthenSpineInstruction"/>
        <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lower back is compressed.</core:errorDescription>
        <rdfs:label>CompressedLowerBackError</rdfs:label>
      </core:PoseError>
    </core:hasPossibleError>
    <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#ShoulderTensionError"/>
    <core:hasRule>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#ControlledBackbendRule">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
        <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the backbend controlled.</core:ruleDescription>
        <rdfs:label>ControlledBackbendRule</rdfs:label>
      </owl:NamedIndividual>
    </core:hasRule>
    <core:hasRule>
      <core:PostureRule rdf:about="http://example.org/suryanamaskar/base-sn#ArmsRaisedOverheadRule">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:label>ArmsRaisedOverheadRule</rdfs:label>
        <core:ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Raise the arms overhead.</core:ruleDescription>
      </core:PostureRule>
    </core:hasRule>
    <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ChestOpenRule"/>
    <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose02"/>
    <core:hasPreviousPose>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose10">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <core:hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</core:hasLaterality>
        <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose11"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#ExcessiveKneeBendError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RoundedBackError"/>
        <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10</core:poseNumber>
        <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose09"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ForwardBendFromHipsRule"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#HeadRelaxedRule"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#SpineElongatedRule"/>
        <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#ForwardBendConstraint"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Knee"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Hip"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Feet"/>
        <core:hasChakra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Swadhisthana</core:hasChakra>
        <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">StandingBentTwoFeet</core:hasSupportType>
        <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
        <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#Padahastasana"/>
        <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose03"/>
        <rdfs:label>BaseSN_Pose10</rdfs:label>
        <core:hasMantra rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om Hraim/Om Savitre Namah</core:hasMantra>
      </owl:NamedIndividual>
    </core:hasPreviousPose>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">11</core:poseNumber>
    <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#HastaUtthanasana"/>
    <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <rdfs:label>BaseSN_Pose11</rdfs:label>
    <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose12"/>
    <core:hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">StandingTwoFeet</core:hasSupportType>
    <core:hasConstraint>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#UprightBackbendConstraint">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
        <core:constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Upright posture with a gentle backbend.</core:constraintDescription>
        <rdfs:label>UprightBackbendConstraint</rdfs:label>
      </owl:NamedIndividual>
    </core:hasConstraint>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#RoundedBackError">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Back is rounded.</core:errorDescription>
    <core:hasCorrection>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#LengthenSpineInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <rdfs:label>LengthenSpineInstruction</rdfs:label>
        <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lengthen the spine.</core:correctionText>
      </owl:NamedIndividual>
    </core:hasCorrection>
    <core:hasCorrection>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BendFromHipsInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <rdfs:label>BendFromHipsInstruction</rdfs:label>
        <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bend forward from the hips.</core:correctionText>
      </owl:NamedIndividual>
    </core:hasCorrection>
    <rdfs:label>RoundedBackError</rdfs:label>
  </owl:NamedIndividual>
  <core:CorrectionInstruction rdf:about="http://example.org/suryanamaskar/base-sn#ExtendBackLegInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>ExtendBackLegInstruction</rdfs:label>
    <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Extend the back leg fully.</core:correctionText>
  </core:CorrectionInstruction>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#SaggingHipsError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <core:hasCorrection>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#KeepBodyAlignedInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <rdfs:label>KeepBodyAlignedInstruction</rdfs:label>
        <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the body aligned in one straight line.</core:correctionText>
      </owl:NamedIndividual>
    </core:hasCorrection>
    <core:hasCorrection>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#EngageCoreInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <rdfs:label>EngageCoreInstruction</rdfs:label>
        <core:correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Engage the core.</core:correctionText>
      </owl:NamedIndividual>
    </core:hasCorrection>
    <rdfs:label>SaggingHipsError</rdfs:label>
    <core:errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hips are sagging downward.</core:errorDescription>
  </core:PoseError>
  <core:PoseError rdf:about="http://example.org/suryanamaskar/base-sn#WristOverloadError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>WristOverloadError</rdfs:label>
