    <rdfs:label>Pranamasana</rdfs:label>
    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">20</hasCYPPage>
  </Asana>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Knee">
