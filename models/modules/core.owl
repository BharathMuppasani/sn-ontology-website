  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Chest">
    <rdfs:label>Chest</rdfs:label>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#BodyPart"/>
  </owl:NamedIndividual>
