  <!-- CYP Enrichment Individuals -->
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Vrksasana">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label>Vrksasana</rdfs:label>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tree Pose</hasAlternateName>
