    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasPossibleError">
    <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdfs:label>has possible error</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasAlternateName">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label>has alternate name</rdfs:label>
  </owl:DatatypeProperty>
  <Asana rdf:about="http://example.org/suryanamaskar/core#Bhujangasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">33</hasCYPPage>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bhujang-asana</hasAlternateName>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cobra pose</hasAlternateName>
    <rdfs:label>Bhujangasana</rdfs:label>
  </Asana>
  <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#constraintDescription">
    <rdfs:label>constraint description</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
