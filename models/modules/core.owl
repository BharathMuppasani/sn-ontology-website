  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasChakra">
    <rdfs:label>has chakra</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
  </owl:DatatypeProperty>
  <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
  <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#sameAsanaAs">
    <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label>same asana as</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasMantra">
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>has mantra</rdfs:label>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#ruleDescription">
    <rdfs:label>rule description</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
  </owl:DatatypeProperty>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Shoulder">
    <rdfs:label>Shoulder</rdfs:label>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#BodyPart"/>
  </owl:NamedIndividual>
  <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#errorDescription">
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
