    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
  </owl:DatatypeProperty>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Neck">
    <rdfs:label>Neck</rdfs:label>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#BodyPart"/>
  </owl:NamedIndividual>
