    <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Variant"/>
    <rdfs:label>belongs to variant</rdfs:label>
  </owl:ObjectProperty>
  <owl:Ontology rdf:about="http://example.org/suryanamaskar/core">
    <dc:title>Surya Namaskar Core Ontology</dc:title>
    <dc:description>Core ontology for Surya Namaskar variants, containing shared classes, properties, asana individuals, and body-part individuals.</dc:description>
    <rdfs:label>Surya Namaskar Core Ontology</rdfs:label>
  </owl:Ontology>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#AshtangaNamaskara">
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ashtanga namaskara</hasAlternateName>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Salute with eight parts or points</hasAlternateName>
    <rdfs:label>Ashtanga Namaskara</rdfs:label>
    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">34</hasCYPPage>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Hands">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#BodyPart"/>
    <rdfs:label>Hands</rdfs:label>
  </owl:NamedIndividual>
  <BodyPart rdf:about="http://example.org/suryanamaskar/core#Spine">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Spine</rdfs:label>
  </BodyPart>
  <Asana rdf:about="http://example.org/suryanamaskar/core#UrdhwaMukhaSvanasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Urdhwa Mukha Svanasana</rdfs:label>
    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">33</hasCYPPage>
  </Asana>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Samasthiti">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label>Samasthiti</rdfs:label>
    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">20</hasCYPPage>
  </owl:NamedIndividual>
  <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Parvatasana">
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mountain pose</hasAlternateName>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parvat-asana</hasAlternateName>
    <sameAsanaAs>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#AdhoMukhaSvanasana">
        <sameAsanaAs rdf:resource="http://example.org/suryanamaskar/core#Parvatasana"/>
        <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adho mukha svanasana</hasAlternateName>
        <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adhomukha swanasana</hasAlternateName>
        <rdfs:label>Adho Mukha Svanasana</rdfs:label>
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
      </owl:NamedIndividual>
    </sameAsanaAs>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label>Parvatasana</rdfs:label>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Uttanasana">
    <rdfs:label>Uttanasana</rdfs:label>
    <sameAsanaAs>
      <Asana rdf:about="http://example.org/suryanamaskar/core#Padahastasana">
        <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hand to foot pose</hasAlternateName>
        <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Padahathasana</hasAlternateName>
        <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pada hastasana</hasAlternateName>
        <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Padahast-asana</hasAlternateName>
        <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Padahasta-sana</hasAlternateName>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <sameAsanaAs rdf:resource="http://example.org/suryanamaskar/core#Uttanasana"/>
        <rdfs:label>Padahastasana</rdfs:label>
        <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">22</hasCYPPage>
      </Asana>
    </sameAsanaAs>
    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">22</hasCYPPage>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Phalakasana">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Plank pose</hasAlternateName>
    <rdfs:label>Phalakasana</rdfs:label>
    <sameAsanaAs>
      <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#ChaturangaDandasana">
        <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chaturanga Dandasan</hasAlternateName>
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <sameAsanaAs rdf:resource="http://example.org/suryanamaskar/core#Phalakasana"/>
        <rdfs:label>Chaturanga Dandasana</rdfs:label>
      </owl:NamedIndividual>
    </sameAsanaAs>
  </owl:NamedIndividual>
  <owl:Class rdf:about="http://example.org/suryanamaskar/core#PostureRule">
    <rdfs:label>Posture Rule</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/suryanamaskar/core#Asana">
    <rdfs:label>Asana</rdfs:label>
