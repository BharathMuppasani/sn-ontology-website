<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns="http://example.org/suryanamaskar/core#"
  xmlns:dc="http://purl.org/dc/elements/1.1/"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
>
  <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasAsana">
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label>has asana</rdfs:label>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#correctionText">
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label>correction text</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasConstraint">
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
    <rdfs:label>has constraint</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasNextPose">
    <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasPreviousPose">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:label>has previous pose</rdfs:label>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
    <rdfs:label>has next pose</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
  </owl:ObjectProperty>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#HastaUtthanasana">
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hasta Utthan-asana</hasAlternateName>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hastha uthanasana</hasAlternateName>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Raised arms pose</hasAlternateName>
    <rdfs:label>Hasta Utthanasana</rdfs:label>
    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">23</hasCYPPage>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Legs">
    <rdfs:label>Legs</rdfs:label>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#BodyPart"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#Tadasana">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label>Tadasana</rdfs:label>
    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">20</hasCYPPage>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#AshwaSanchalanasana">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ashwasanchalanasana</hasAlternateName>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ashwa Sanchalan-asana</hasAlternateName>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Equestrian pose</hasAlternateName>
    <rdfs:label>Ashwa Sanchalanasana</rdfs:label>
  </owl:NamedIndividual>
  <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasCYPPage">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label>has CYP page</rdfs:label>
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasCorrection">
    <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
    <rdfs:label>has correction</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
  </owl:ObjectProperty>
  <BodyPart rdf:about="http://example.org/suryanamaskar/core#Wrist">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Wrist</rdfs:label>
  </BodyPart>
