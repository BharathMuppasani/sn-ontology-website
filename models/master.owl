    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasCYPPage -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasCYPPage">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has CYP page</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasChakra -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasChakra">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has chakra</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasLaterality -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasLaterality">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has laterality</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasMantra -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasMantra">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has mantra</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasSupportType -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasSupportType">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has support type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#poseNumber -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#poseNumber">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>pose number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#ruleDescription -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#ruleDescription">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>rule description</rdfs:label>
    </owl:DatatypeProperty>
    


