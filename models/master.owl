<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/suryanamaskar/master#"
     xml:base="http://example.org/suryanamaskar/master"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:core="http://example.org/suryanamaskar/core#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/suryanamaskar/master">
        <dc:description>Base SN variant ontology containing Base SN variant individual, pose occurrences, sequence relations, and Base SN-specific correction resources.</dc:description>
        <dc:description>Core ontology for Surya Namaskar variants, containing shared classes, properties, asana individuals, and body-part individuals.</dc:description>
        <dc:description>Master ontology importing the shared core, Base SN, and Variant 01-03 ontologies.</dc:description>
        <dc:description>Variant 01 ontology containing the Krishnamacharya Vinyasa variant individual, 13 pose occurrences, and their sequence-specific relations and values.</dc:description>
        <dc:description>Variant 03 ontology containing Swami Vivekananda Kendra variant individual, pose occurrences, and sequence relations.</dc:description>
        <dc:description>Variant 02-specific individuals and assertions extracted from the original combined Surya Namaskar ontology; imports the shared core ontology.</dc:description>
        <dc:title>Surya Namaskar Base Sequence Ontology</dc:title>
        <dc:title>Surya Namaskar Core Ontology</dc:title>
        <dc:title>Surya Namaskar Master Ontology</dc:title>
        <dc:title>Surya Namaskar Variant 01 Krishnamacharya Vinyasa Ontology</dc:title>
        <dc:title>Surya Namaskar Variant 03 Ontology</dc:title>
        <dc:title>Variant 02 Bihar School of Yoga Ontology</dc:title>
        <rdfs:label>Surya Namaskar Base Sequence Ontology</rdfs:label>
        <rdfs:label>Surya Namaskar Core Ontology</rdfs:label>
        <rdfs:label>Surya Namaskar Master Ontology</rdfs:label>
        <rdfs:label>Surya Namaskar Variant 01 Ontology</rdfs:label>
        <rdfs:label>Surya Namaskar Variant 03 Ontology</rdfs:label>
        <rdfs:label>Variant 02 Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#comment -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#comment"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#label -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#label"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/suryanamaskar/core#belongsToVariant -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#belongsToVariant">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Variant"/>
        <rdfs:label>belongs to variant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasAsana -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasAsana">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <rdfs:label>has asana</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasConstraint -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasConstraint">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
        <rdfs:label>has constraint</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasCorrection -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasCorrection">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <rdfs:label>has correction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasInversePose -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasInversePose">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:label>has inverse pose</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasNextPose -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasNextPose">
        <owl:inverseOf rdf:resource="http://example.org/suryanamaskar/core#hasPreviousPose"/>
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:label>has next pose</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasPossibleError -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasPossibleError">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
        <rdfs:label>has possible error</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasPreviousPose -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasPreviousPose">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:label>has previous pose</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasRule -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasRule">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
        <rdfs:label>has rule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#involvesBodyPart -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#involvesBodyPart">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#BodyPart"/>
        <rdfs:label>involves body part</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#repeatsPose -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#repeatsPose">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:label>repeats pose</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#sameAsanaAs -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#sameAsanaAs">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <rdfs:label>same asana as</rdfs:label>
    </owl:ObjectProperty>
    


