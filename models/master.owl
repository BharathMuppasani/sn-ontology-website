        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>correction text</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#errorDescription -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#errorDescription">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>error description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasAlternateName -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasAlternateName">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
