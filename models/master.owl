    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#constraintDescription">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>constraint description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#correctionText -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#correctionText">
