    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/suryanamaskar/base-sn#AlignFrontKneeInstruction -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#AlignFrontKneeInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <core:correctionText>Align the front knee above or near the ankle.</core:correctionText>
        <rdfs:label>AlignFrontKneeInstruction</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/suryanamaskar/base-sn#AlignPalmsAtChestInstruction -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#AlignPalmsAtChestInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <core:correctionText>Align the palms at the chest.</core:correctionText>
        <rdfs:label>AlignPalmsAtChestInstruction</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/suryanamaskar/base-sn#ArmAndToeSupportConstraint -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#ArmAndToeSupportConstraint">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
        <core:constraintDescription>Full body support on arms and toes.</core:constraintDescription>
        <rdfs:label>ArmAndToeSupportConstraint</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/suryanamaskar/base-sn#ArmsRaisedOverheadRule -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#ArmsRaisedOverheadRule">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
        <core:ruleDescription>Raise the arms overhead.</core:ruleDescription>
        <rdfs:label>ArmsRaisedOverheadRule</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/suryanamaskar/base-sn#BackExtensionWithPelvisGroundedConstraint -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BackExtensionWithPelvisGroundedConstraint">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PoseConstraint"/>
        <core:constraintDescription>Backward spinal extension with the pelvis grounded.</core:constraintDescription>
        <rdfs:label>BackExtensionWithPelvisGroundedConstraint</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/suryanamaskar/base-sn#BackLegExtendedRule -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BackLegExtendedRule">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#PostureRule"/>
        <core:ruleDescription>Keep the back leg extended.</core:ruleDescription>
        <rdfs:label>BackLegExtendedRule</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/suryanamaskar/base-sn#BalanceWeightEvenlyInstruction -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BalanceWeightEvenlyInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <core:correctionText>Balance weight evenly on both feet.</core:correctionText>
        <rdfs:label>BalanceWeightEvenlyInstruction</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/suryanamaskar/base-sn#BaseSN_Pose01 -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose01">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
        <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#Pranamasana"/>
        <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#SymmetricalStandingConstraint"/>
        <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose02"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#CollapsedChestError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#PalmsMisalignedError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RoundedShouldersError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#UnevenWeightError"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ChestOpenRule"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#PalmsTogetherRule"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ShouldersRelaxedRule"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#UprightPostureRule"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chest"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Feet"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Neck"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Palms"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Shoulder"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
        <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose12"/>
        <core:hasChakra>Anahata</core:hasChakra>
        <core:hasLaterality>Symmetric</core:hasLaterality>
        <core:hasMantra>Om Hraam/Om Mitraya Namah</core:hasMantra>
        <core:hasSupportType>StandingTwoFeet</core:hasSupportType>
        <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</core:poseNumber>
        <rdfs:label>BaseSN_Pose01</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/suryanamaskar/base-sn#BaseSN_Pose02 -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose02">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
        <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#HastaUtthanasana"/>
        <core:hasConstraint rdf:resource="http://example.org/suryanamaskar/base-sn#MildSpinalExtensionConstraint"/>
        <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose03"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#BentArmsError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#LowerBackOverarchingError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#NeckStrainError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RaisedShouldersError"/>
        <core:hasPreviousPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose01"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ArmsRaisedOverheadRule"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ChestOpenRule"/>
        <core:hasRule rdf:resource="http://example.org/suryanamaskar/base-sn#ControlledBackbendRule"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Arms"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chest"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Hip"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Neck"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Shoulder"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
        <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose11"/>
        <core:hasChakra>Vishuddhi</core:hasChakra>
        <core:hasLaterality>Symmetric</core:hasLaterality>
