<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/suryanamaskar/master#"
     xml:base="http://example.org/suryanamaskar/master"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dc="http://purl.org/dc/elements/1.1/">

  <owl:Ontology rdf:about="http://example.org/suryanamaskar/master">
    <owl:imports rdf:resource="http://example.org/suryanamaskar/core"/>
    <owl:imports rdf:resource="http://example.org/suryanamaskar/base-sn"/>
    <owl:imports rdf:resource="http://example.org/suryanamaskar/variant01"/>
    <owl:imports rdf:resource="http://example.org/suryanamaskar/variant02"/>
    <owl:imports rdf:resource="http://example.org/suryanamaskar/variant03"/>
    <rdfs:label>Surya Namaskar Master Ontology</rdfs:label>
    <dc:title>Surya Namaskar Master Ontology</dc:title>
    <dc:description>Master ontology importing the shared core, Base SN, and Variant 01-03 ontologies.</dc:description>
  </owl:Ontology>

</rdf:RDF>
