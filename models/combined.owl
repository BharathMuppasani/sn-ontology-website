    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseError"/>
    <rdfs:label>ShoulderTensionError</rdfs:label>
    <hasCorrection rdf:resource="#RelaxShouldersInstruction"/>
    <errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shoulders are tense.</errorDescription>
  </rdf:Description>
