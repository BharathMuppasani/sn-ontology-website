  </rdf:Description>
  <rdf:Description rdf:about="#correctionText">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="#CorrectionInstruction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>correction text</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#SpineElongatedRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PostureRule"/>
    <rdfs:label>SpineElongatedRule</rdfs:label>
    <ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the spine elongated.</ruleDescription>
  </rdf:Description>
