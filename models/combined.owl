    <hasCorrection rdf:resource="#SoftenKneesInstruction"/>
    <errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Knees are bent too much.</errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#HipHingeConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseConstraint"/>
    <rdfs:label>HipHingeConstraint</rdfs:label>
    <constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Forward fold with a hip hinge movement.</constraintDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#UrdhwaMukhaSvanasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#Asana"/>
    <rdfs:label>Urdhwa Mukha Svanasana</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#UprightPostureRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PostureRule"/>
    <rdfs:label>UprightPostureRule</rdfs:label>
    <ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Maintain an upright posture.</ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#PalmsMisalignedError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseError"/>
    <rdfs:label>PalmsMisalignedError</rdfs:label>
    <hasCorrection rdf:resource="#AlignPalmsAtChestInstruction"/>
    <errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Palms are not aligned properly.</errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#PushHipsUpwardInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#CorrectionInstruction"/>
    <rdfs:label>PushHipsUpwardInstruction</rdfs:label>
    <correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Push the hips upward.</correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="#Variant01_Pose03">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#Pose"/>
    <rdfs:label>Variant01_Pose03</rdfs:label>
    <poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</poseNumber>
    <hasAsana rdf:resource="#Uttanasana"/>
    <belongsToVariant rdf:resource="#Variant01_KrishnamacharyaVinyasa"/>
    <hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">StandingBentTwoFeet</hasSupportType>
    <hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</hasLaterality>
    <hasNextPose rdf:resource="#Variant01_Pose04"/>
    <hasPreviousPose rdf:resource="#Variant01_Pose02"/>
    <repeatsPose rdf:resource="#Variant01_Pose11"/>
  </rdf:Description>
  <rdf:Description rdf:about="#ChestOpenRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PostureRule"/>
    <rdfs:label>ChestOpenRule</rdfs:label>
    <ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the chest open.</ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#BentArmsError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseError"/>
    <rdfs:label>BentArmsError</rdfs:label>
    <hasCorrection rdf:resource="#KeepArmsStraightInstruction"/>
    <errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Arms are not fully extended.</errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#MaintainHipPositionInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#CorrectionInstruction"/>
    <rdfs:label>MaintainHipPositionInstruction</rdfs:label>
    <correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the hips slightly raised.</correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="#SpinalExtensionRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PostureRule"/>
    <rdfs:label>SpinalExtensionRule</rdfs:label>
    <ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Extend the spine with control.</ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#Variant02_BiharSchoolOfYoga">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#Variant"/>
    <rdfs:label>Variant02_BiharSchoolOfYoga</rdfs:label>
    <rdfs:comment>12 pose Bihar School of Yoga Surya Namaskar.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="#WristOverloadError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseError"/>
    <rdfs:label>WristOverloadError</rdfs:label>
    <hasCorrection rdf:resource="#DistributeWeightEvenlyInstruction"/>
    <hasCorrection rdf:resource="#PushHipsUpwardInstruction"/>
    <errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Too much weight is placed on the wrists.</errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dc:description>Ontology for four Surya Namaskar variants with detailed sequence information and a pose correction layer for the Base SN followed at IIT BHU.</dc:description>
    <dc:title>Surya Namaskar Ontology</dc:title>
    <rdfs:label>Surya Namaskar Ontology</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#RoundedBackError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseError"/>
    <rdfs:label>RoundedBackError</rdfs:label>
    <hasCorrection rdf:resource="#BendFromHipsInstruction"/>
    <hasCorrection rdf:resource="#LengthenSpineInstruction"/>
    <errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Back is rounded.</errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#hasCYPPage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="#Asana"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>has CYP page</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#CorrectionInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Correction Instruction</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#OneLegLungeSupportConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseConstraint"/>
    <rdfs:label>OneLegLungeSupportConstraint</rdfs:label>
    <constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lunge support with one leg forward and hands grounded.</constraintDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#RaisedHipsError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseError"/>
    <rdfs:label>RaisedHipsError</rdfs:label>
    <hasCorrection rdf:resource="#KeepBodyAlignedInstruction"/>
    <errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hips are raised too high.</errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#UnevenWeightError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseError"/>
    <rdfs:label>UnevenWeightError</rdfs:label>
    <hasCorrection rdf:resource="#BalanceWeightEvenlyInstruction"/>
    <errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Weight is not balanced on both feet.</errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#hasCorrection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="#PoseError"/>
    <rdfs:range rdf:resource="#CorrectionInstruction"/>
    <rdfs:label>has correction</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#hasPossibleError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="#Pose"/>
    <rdfs:range rdf:resource="#PoseError"/>
    <rdfs:label>has possible error</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#BendFromHipsInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#CorrectionInstruction"/>
    <rdfs:label>BendFromHipsInstruction</rdfs:label>
    <correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bend forward from the hips.</correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="#Core">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#BodyPart"/>
    <rdfs:label>Core</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#FrontKneeAlignedRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PostureRule"/>
    <rdfs:label>FrontKneeAlignedRule</rdfs:label>
    <ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the front knee aligned above or near the ankle.</ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#hasPreviousPose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="#Pose"/>
    <rdfs:range rdf:resource="#Pose"/>
    <rdfs:label>has previous pose</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#AlignFrontKneeInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#CorrectionInstruction"/>
    <rdfs:label>AlignFrontKneeInstruction</rdfs:label>
    <correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Align the front knee above or near the ankle.</correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="#Feet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#BodyPart"/>
    <rdfs:label>Feet</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#KeepArmsStraightInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#CorrectionInstruction"/>
    <rdfs:label>KeepArmsStraightInstruction</rdfs:label>
    <correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keep the arms straight.</correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="#KneeBeyondAnkleError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseError"/>
    <rdfs:label>KneeBeyondAnkleError</rdfs:label>
    <hasCorrection rdf:resource="#AlignFrontKneeInstruction"/>
    <errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Front knee moves too far beyond the ankle.</errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#ForwardBendConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseConstraint"/>
    <rdfs:label>ForwardBendConstraint</rdfs:label>
    <constraintDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Controlled standing forward bend.</constraintDescription>
  </rdf:Description>
