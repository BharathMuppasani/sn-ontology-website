    <rdfs:label>Danda Samarpana</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#EngageCoreInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#CorrectionInstruction"/>
    <rdfs:label>EngageCoreInstruction</rdfs:label>
    <correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Engage the core.</correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="#RaisedShouldersError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseError"/>
