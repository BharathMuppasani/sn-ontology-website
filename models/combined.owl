    <rdfs:label>ForwardBendFromHipsRule</rdfs:label>
    <ruleDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bend forward from the hips.</ruleDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#RelaxShouldersInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#CorrectionInstruction"/>
    <rdfs:label>RelaxShouldersInstruction</rdfs:label>
    <correctionText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relax the shoulders.</correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="#Neck">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#BodyPart"/>
    <rdfs:label>Neck</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="#UnstableLegsError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#PoseError"/>
    <rdfs:label>UnstableLegsError</rdfs:label>
    <hasCorrection rdf:resource="#StabilizeLegsInstruction"/>
    <errorDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legs are unstable or poorly aligned.</errorDescription>
  </rdf:Description>
  <rdf:Description rdf:about="#Variant03_SwamiVivekanandaKendra">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#Variant"/>
    <rdfs:label>Variant03_SwamiVivekanandaKendra</rdfs:label>
    <rdfs:comment>12 pose Swami Vivekananda Kendra Surya Namaskar.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="#Variant03_Pose07">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="#Pose"/>
    <rdfs:label>Variant03_Pose07</rdfs:label>
    <poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</poseNumber>
    <hasAsana rdf:resource="#Bhujangasana"/>
    <belongsToVariant rdf:resource="#Variant03_SwamiVivekanandaKendra"/>
    <hasSupportType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prone</hasSupportType>
    <hasLaterality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symmetric</hasLaterality>
    <hasNextPose rdf:resource="#Variant03_Pose08"/>
    <hasPreviousPose rdf:resource="#Variant03_Pose06"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/elements/1.1/title">
